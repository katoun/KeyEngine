cmake_minimum_required(VERSION 3.20)

project({{ProjectName}} LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

if(NOT CMAKE_BUILD_TYPE AND NOT CMAKE_CONFIGURATION_TYPES)
    set(CMAKE_BUILD_TYPE Debug CACHE STRING "Build type" FORCE)
endif()

set(KEY_ENGINE_SDK_PATH "" CACHE PATH "Path to the KeyEngine SDK root")
if(NOT EXISTS "${KEY_ENGINE_SDK_PATH}/Source/Runtime/Runtime.h")
    message(FATAL_ERROR "KEY_ENGINE_SDK_PATH must point to the KeyEngine SDK root")
endif()

set(CMAKE_LIBRARY_OUTPUT_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/Build/Linux")
set(CMAKE_DEBUG_POSTFIX "_d")

set(KEY_ENGINE_SDK_BUILD_DIR "${KEY_ENGINE_SDK_PATH}/Build/Linux-Debug" CACHE PATH "Path to the configured KeyEngine SDK build tree")
set(KEY_ENGINE_SDK_DEPS_DIR "${KEY_ENGINE_SDK_BUILD_DIR}/_deps")
if(NOT EXISTS "${KEY_ENGINE_SDK_DEPS_DIR}/glm-src/glm/glm.hpp")
    message(FATAL_ERROR "KeyEngine SDK dependencies were not found. Configure the SDK first, or set KEY_ENGINE_SDK_BUILD_DIR.")
endif()

add_library(ProjectThirdParty_glm INTERFACE)
add_library(ProjectThirdParty::glm ALIAS ProjectThirdParty_glm)
target_include_directories(ProjectThirdParty_glm INTERFACE "${KEY_ENGINE_SDK_DEPS_DIR}/glm-src")

add_library(ProjectThirdParty_rapidjson INTERFACE)
add_library(ProjectThirdParty::rapidjson ALIAS ProjectThirdParty_rapidjson)
target_include_directories(ProjectThirdParty_rapidjson INTERFACE "${KEY_ENGINE_SDK_DEPS_DIR}/rapidjson-src/include")

add_library(ProjectThirdParty_base64 INTERFACE)
add_library(ProjectThirdParty::base64 ALIAS ProjectThirdParty_base64)
target_include_directories(ProjectThirdParty_base64 INTERFACE "${KEY_ENGINE_SDK_DEPS_DIR}/cereal-src/include/cereal/external")

file(GLOB_RECURSE PROJECT_SOURCES CONFIGURE_DEPENDS
    "Source/*.cpp"
)

add_library({{ProjectName}}EditorModule SHARED ${PROJECT_SOURCES})
target_compile_definitions({{ProjectName}}EditorModule
    PRIVATE
        PROJECT_DLL
        PROJECT_EXPORTS
        RUNTIME_DLL
        PLATFORM_LINUX
        BUILD_OS_LINUX
        $<$<CONFIG:Debug>:_DEBUG>
)
target_include_directories({{ProjectName}}EditorModule
    PRIVATE
        "${CMAKE_CURRENT_SOURCE_DIR}/Source"
        "${CMAKE_CURRENT_SOURCE_DIR}/Source/.Generated"
        "${KEY_ENGINE_SDK_PATH}/Source/Runtime"
)

set(KEY_RUNTIME_LIBRARY "${KEY_ENGINE_SDK_PATH}/Build/Linux/libKeyRuntime.so")
if(CMAKE_BUILD_TYPE STREQUAL "Debug")
    set(KEY_RUNTIME_LIBRARY "${KEY_ENGINE_SDK_PATH}/Build/Linux/libKeyRuntime_d.so")
endif()

target_link_libraries({{ProjectName}}EditorModule
    PRIVATE
        "${KEY_RUNTIME_LIBRARY}"
        ProjectThirdParty::base64
        ProjectThirdParty::glm
        ProjectThirdParty::rapidjson
)
set_target_properties({{ProjectName}}EditorModule PROPERTIES
    PREFIX ""
    OUTPUT_NAME "{{ProjectName}}-EditorModule"
)
